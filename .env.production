# Production Environment Configuration
# Copy to .env and customize

# ptdata API (legislation)
PTDATA_API_KEY=your_ptdata_api_key
PTDATA_API_URL=https://api.ptdata.org/mcp

# IAEDU (free LLM for Portuguese universities)
# Set USE_IAEDU=true to use iaedu.pt
USE_IAEDU=false
IAEDU_API_KEY=your_iaedu_api_key
IAEDU_ENDPOINT=https://api.iaedu.pt/agent-chat/api/v1/agent/cmamvd3n40000c801qeacoad2/stream
IAEDU_CHANNEL_ID=cmh0rfgmn0i64j801uuoletwy
IAEDU_MODEL_NAME=iaedu-gpt4o

# Database (production)
DATABASE_URL=postgresql://postgres:postgres@db:5432/tax_intelligence

# Redis Cache
REDIS_URL=redis://cache:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change_this_in_production

# Logging
LOG_LEVEL=INFO

# Cache TTL (seconds)
CACHE_TTL_SECONDS=86400

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_BURST=10
