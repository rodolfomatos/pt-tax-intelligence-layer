# ptdata API
PTDATA_API_KEY=your_ptdata_api_key_here
PTDATA_API_URL=https://api.ptdata.org/mcp

# LLM (OpenAI or Ollama)
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gpt-4

# IAEDU (Free for Portuguese universities - iaedu.pt)
# Set USE_IAEDU=true to use iaedu.pt instead of OpenAI/Ollama
USE_IAEDU=false
IAEDU_API_KEY=your_iaedu_api_key_here
IAEDU_ENDPOINT=https://api.iaedu.pt/agent-chat/api/v1/agent/cmamvd3n40000c801qeacoad2/stream
IAEDU_CHANNEL_ID=cmh0rfgmn0i64j801uuoletwy
IAEDU_MODEL_NAME=iaedu-gpt4o

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tax_intelligence

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your_api_key_here

# Logging
LOG_LEVEL=INFO

# Cache TTL (seconds)
CACHE_TTL_SECONDS=86400

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_BURST=10
